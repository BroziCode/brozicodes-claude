{
  "name": "brozicode-server",
  "version": "0.10.2",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.js --bundle --platform=node --format=esm --outfile=bundle.js --banner:js='import { createRequire } from \"module\"; const require = createRequire(import.meta.url);'",
    "test": "node test/skeleton.test.mjs && node test/batch-edit.test.mjs",
    "verify": "npm test && npm run build",
    "bench": "node bench/e2e.mjs",
    "dev": "node --watch src/index.js"
  },
  "dependencies": {
    "@babel/parser": "^7.29.3",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "diff": "^7.0.0",
    "fast-glob": "^3.3.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.0"
  }
}
